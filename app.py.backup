@app.route("/laporan_hutang", methods=["GET"])
def laporan_hutang():

    cur = conn.cursor()

    cur.execute("""
        SELECT
            tanggal,
            supplier,
            barang,
            total,
            sudah_dibayar,
            (total - sudah_dibayar) as sisa_hutang
        FROM pembelian
        WHERE status='HUTANG'
        AND (total - sudah_dibayar) > 0
    """)

    rows = cur.fetchall()

    cur.close()

    data = []

    for row in rows:
        data.append({
            "tanggal": str(row[0]),
            "supplier": row[1],
            "barang": row[2],
            "total": float(row[3]),
            "sudah_dibayar": float(row[4]),
            "sisa_hutang": float(row[5])
        })

    return jsonify(data)
