@app.route("/pembayaran_supplier", methods=["GET"])
def get_pembayaran_supplier():

    cur = conn.cursor()

    cur.execute("""
        SELECT
            tanggal,
            supplier,
            nominal,
            keterangan
        FROM pembayaran_supplier
        ORDER BY id DESC
    """)

    rows = cur.fetchall()

    cur.close()

    data = []

    for row in rows:
        data.append({
            "tanggal": str(row[0]),
            "supplier": row[1],
            "nominal": float(row[2]),
            "keterangan": row[3]
        })

    return jsonify(data)


@app.route("/simpan_pembayaran_supplier", methods=["POST"])
def simpan_pembayaran_supplier():

    data = request.get_json()

    cur = conn.cursor()

    # CEK DUPLIKAT
    cur.execute("""
        SELECT COUNT(*)
        FROM pembayaran_supplier
        WHERE tanggal=%s
        AND supplier=%s
        AND nominal=%s
    """, (
        data["tanggal"],
        data["supplier"],
        data["nominal"]
    ))

    cek = cur.fetchone()[0]

    if cek > 0:
        cur.close()

        return jsonify({
            "message":"Pembayaran supplier sudah pernah diinput"
        })

    # Simpan riwayat pembayaran
    cur.execute("""
        INSERT INTO pembayaran_supplier
        (tanggal,supplier,nominal,keterangan)
        VALUES (%s,%s,%s,%s)
    """, (
        data["tanggal"],
        data["supplier"],
        data["nominal"],
        data["keterangan"]
    ))

    # Kurangi kas
    cur.execute("""
        INSERT INTO kas
        (tanggal,keterangan,masuk,keluar)
        VALUES (%s,%s,%s,%s)
    """, (
        data["tanggal"],
        "PEMBAYARAN HUTANG SUPPLIER",
        0,
        data["nominal"]
    ))

    # Bayar hutang tertua terlebih dahulu
    sisa_bayar = float(data["nominal"])

    cur.execute("""
        SELECT id,total,sudah_dibayar
        FROM pembelian
        WHERE status='HUTANG'
        AND supplier=%s
        AND total > sudah_dibayar
        ORDER BY tanggal,id
    """, (data["supplier"],))

    hutang_list = cur.fetchall()

    for hutang in hutang_list:

        id_pembelian = hutang[0]
        total = float(hutang[1])
        sudah_dibayar = float(hutang[2])

        sisa_hutang = total - sudah_dibayar

        if sisa_bayar <= 0:
            break

        bayar = min(sisa_bayar, sisa_hutang)

        cur.execute("""
            UPDATE pembelian
            SET sudah_dibayar = sudah_dibayar + %s
            WHERE id=%s
        """, (
            bayar,
            id_pembelian
        ))

        sisa_bayar -= bayar

    conn.commit()
    cur.close()

    return jsonify({
        "message":"Pembayaran supplier berhasil disimpan"
    })
