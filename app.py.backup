# =========================
# MASTER BARANG
# =========================

@app.route("/barang", methods=["GET"])
def get_barang():
    cur = conn.cursor()
    cur.execute("""
        SELECT kode,nama,harga_beli,harga_jual,stok
        FROM barang
        ORDER BY nama
    """)
    rows = cur.fetchall()
    cur.close()

    data = []
    for row in rows:
        data.append({
            "kode": row[0],
            "nama": row[1],
            "harga_beli": float(row[2]),
            "harga_jual": float(row[3]),
            "stok": int(row[4])
        })

    return jsonify(data)

@app.route("/simpan_barang", methods=["POST"])
def simpan_barang():
    data = request.get_json()

    cur = conn.cursor()
    cur.execute("""
        INSERT INTO barang
        (kode,nama,harga_beli,harga_jual,stok)
        VALUES (%s,%s,%s,%s,%s)
    """, (
        data["kode"],
        data["nama"],
        data["hargaBeli"],
        data["hargaJual"],
        data["stok"]
    ))
    conn.commit()
    cur.close()

    return jsonify({"message":"Barang berhasil disimpan"})

